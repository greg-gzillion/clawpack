# ============ SESSION MANAGEMENT ============
SESSION_DIR = os.path.expanduser("~/.claw_sessions")
os.makedirs(SESSION_DIR, exist_ok=True)
current_session = None
session_data = {"conversations": [], "created": None, "total_cost": 0, "total_tokens": 0}

def session_new(name=None):
    global current_session, session_data
    if not name:
        name = f"session_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
    current_session = name
    session_data = {
        "id": name,
        "created": datetime.now().isoformat(),
        "conversations": [],
        "total_cost": 0,
        "total_tokens": 0
    }
    session_save()
    print(f"New session: {name}")

def session_save():
    if current_session:
        path = os.path.join(SESSION_DIR, f"{current_session}.json")
        with open(path, 'w') as f:
            json.dump(session_data, f, indent=2)

def session_load(name):
    global current_session, session_data
    path = os.path.join(SESSION_DIR, f"{name}.json")
    if os.path.exists(path):
        with open(path, 'r') as f:
            session_data = json.load(f)
        current_session = name
        print(f"Loaded session: {name} ({len(session_data.get('conversations', []))} messages)")
        return True
    print(f"Session not found: {name}")
    return False

def session_list():
    sessions = glob.glob(os.path.join(SESSION_DIR, "*.json"))
    if not sessions:
        print("No saved sessions")
        return
    print("\nSaved sessions:")
    for s in sessions:
        name = os.path.basename(s).replace('.json', '')
        with open(s, 'r') as f:
            data = json.load(f)
            print(f"  {name} - {len(data.get('conversations', []))} messages")

def session_compact():
    if current_session:
        convs = session_data.get('conversations', [])
        if len(convs) > 20:
            old = len(convs)
            session_data['conversations'] = convs[-20:]
            session_save()
            print(f"Compacted: {old} -> 20 messages")
        else:
            print(f"Only {len(convs)} messages, no compaction needed")

def session_export(filename=None):
    if not filename:
        filename = f"export_{current_session}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
    with open(filename, 'w') as f:
        json.dump(session_data, f, indent=2)
    print(f"Exported to: {filename}")

# ============ COST TRACKING ============
def track_cost(prompt_tokens, completion_tokens):
    input_cost = (prompt_tokens / 1_000_000) * 0.59
    output_cost = (completion_tokens / 1_000_000) * 0.79
    total = input_cost + output_cost
    session_data['total_cost'] = session_data.get('total_cost', 0) + total
    session_data['total_tokens'] = session_data.get('total_tokens', 0) + prompt_tokens + completion_tokens
    session_save()
    return total

def show_cost():
    print(f"\nSession: {current_session}")
    print(f"  Messages: {len(session_data.get('conversations', []))}")
    print(f"  Total tokens: {session_data.get('total_tokens', 0)}")
    print(f"  Total cost: ${session_data.get('total_cost', 0):.6f}")

# ============ AI QUERY ============
def read_project_file(filename):
    paths = [
        f"{PROJECT_ROOT}/{filename}",
        f"{PROJECT_ROOT}/docs/{filename}",
        f"{PROJECT_ROOT}/docs/business/{filename}",
    ]
    for path in paths:
        if os.path.exists(path):
            with open(path, 'r') as f:
                return f.read()
    return None

def ask_ai(question):
    if not client:
        return "ERROR: GROQ_API_KEY not set"
    
    context = ""
    question_lower = question.lower()
    
    if any(kw in question_lower for kw in ['phnx', 'trust', 'vision', 'token']):
        content = read_project_file("VISION.md")
        if content:
            context += f"\n[VISION.md]\n{content[:3000]}\n"
    
    if context:
        prompt = f"Based on this file:\n{context}\n\nQuestion: {question}"
    else:
        prompt = question
    
    try:
        completion = client.chat.completions.create(
            model=CURRENT_MODEL,
            messages=[{"role": "user", "content": prompt}],
            max_tokens=1500
        )
        response = completion.choices[0].message.content
        prompt_tokens = len(prompt) // 4
        response_tokens = len(response) // 4
        track_cost(prompt_tokens, response_tokens)
        
        # Save to session
        session_data.setdefault('conversations', []).append({
            'question': question[:200],
            'answer': response[:500],
            'timestamp': datetime.now().isoformat()
        })
        session_save()
        
        return response
    except Exception as e:
        return f"Error: {e}"

# ============ TOOLS (read, grep, edit, glob, find) ============
def tool_read(filepath):
    full_path = os.path.join(PROJECT_ROOT, filepath.lstrip('/'))
    if os.path.exists(full_path):
        with open(full_path, 'r') as f:
            content = f.read()
            lines = len(content.split('\n'))
            print(f"\n[Reading {filepath} - {lines} lines]\n")
            return content[:5000]
    return f"File not found: {filepath}"

def tool_grep(pattern, file_pattern="*.rs"):
    cmd = f"grep -rn '{pattern}' {PROJECT_ROOT} --include='{file_pattern}' 2>/dev/null | head -30"
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout if result.stdout else f"No matches for '{pattern}'"

def tool_edit(filepath, line_number, new_content):
    if PERMISSION_MODE in ["workspace-write", "full"]:
        full_path = os.path.join(PROJECT_ROOT, filepath.lstrip('/'))
        if os.path.exists(full_path):
            with open(full_path, 'r') as f:
                lines = f.readlines()
            if 0 <= line_number - 1 < len(lines):
                lines[line_number - 1] = new_content + '\n'
                with open(full_path, 'w') as f:
                    f.writelines(lines)
                return f"Updated line {line_number} in {filepath}"
        return f"File not found: {filepath}"
    return "Permission denied (requires workspace-write or full)"

def tool_glob(pattern):
    matches = glob.glob(os.path.join(PROJECT_ROOT, f"**/{pattern}"), recursive=True)
    return '\n'.join([m.replace(PROJECT_ROOT, '') for m in matches[:30]])

def tool_find_symbol(symbol_name):
    cmd = f"grep -rn 'fn {symbol_name}\\|struct {symbol_name}\\|enum {symbol_name}' {PROJECT_ROOT} --include='*.rs' 2>/dev/null | head -20"
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout if result.stdout else f"Symbol '{symbol_name}' not found"

def web_search(query):
    try:
        import requests
        from urllib.parse import quote
        print(f"Searching web for: {query}")
        url = f"https://html.duckduckgo.com/html/?q={quote(query)}"
        headers = {'User-Agent': 'Mozilla/5.0'}
        response = requests.get(url, timeout=10, headers=headers)
        if response.status_code == 200:
            import re
            titles = re.findall(r'<a rel="nofollow" class="result__a" href="[^"]+">([^<]+)</a>', response.text)
            results = []
            for i, title in enumerate(titles[:5], 1):
                results.append(f"{i}. {title}")
            return '\n'.join(results) if results else "No results found"
        return f"Search error: HTTP {response.status_code}"
    except Exception as e:
        return f"Search error: {e}"

# ============ TEAM MODE (parallel review) ============
def team_mode(task):
    print("\n👥 TEAM MODE - Parallel Review")
    print("="*40)
    perspectives = [
        "Security expert - find vulnerabilities",
        "Performance engineer - optimize speed",
        "Code architect - improve structure",
        "QA engineer - find edge cases"
    ]
    responses = []
    for i, perspective in enumerate(perspectives, 1):
        print(f"\n[Reviewer {i}: {perspective}]")
        prompt = f"As a {perspective}, review this: {task}\nProvide specific recommendations."
        response = ask_ai(prompt)
        print(response[:400] + "..." if len(response) > 400 else response)
        responses.append(response)
    return responses

# ============ RALPH MODE (persistent execution) ============
def ralph_mode(task, iterations=3):
    print("\n🔄 RALPH MODE - Persistent Execution")
    print("="*40)
    history = []
    for i in range(iterations):
        print(f"\n--- Iteration {i+1}/{iterations} ---")
        context = "\n".join(history[-2:]) if history else ""
        prompt = f"Task: {task}\nPrevious attempts: {context}\nExecute and verify. If failed, try different approach."
        response = ask_ai(prompt)
        print(response[:400] + "..." if len(response) > 400 else response)
        history.append(f"Attempt {i+1}: {response[:100]}")
        if "completed" in response.lower() or "success" in response.lower():
            print(f"\n✅ Completed after {i+1} iterations")
            return response
    print(f"\n⚠️ Not fully completed after {iterations} iterations")
    return response

