# ============ GIT INTEGRATION ============
def git_status():
    result = subprocess.run(f"cd {PROJECT_ROOT} && git status -s", shell=True, capture_output=True, text=True)
    return result.stdout if result.stdout else "Working tree clean"

def git_diff():
    result = subprocess.run(f"cd {PROJECT_ROOT} && git diff --stat", shell=True, capture_output=True, text=True)
    return result.stdout if result.stdout else "No changes"

def git_log(n=5):
    result = subprocess.run(f"cd {PROJECT_ROOT} && git log --oneline -{n}", shell=True, capture_output=True, text=True)
    return result.stdout if result.stdout else "No commits"

